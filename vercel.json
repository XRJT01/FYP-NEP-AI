{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "trailingSlash": false,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/v1/:path*",   "destination": "/api/index" },
    { "source": "/api/openapi.json", "destination": "/api/index" },
    { "source": "/api/docs",         "destination": "/api/index" },
    { "source": "/api/redoc",        "destination": "/api/index" },
    { "source": "/api/health",       "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(self), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/locales/(.*).json",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    },
    {
      "source": "/(index.html|js/.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
      ]
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 10
    }
  }
}
